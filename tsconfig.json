{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": false,
    "moduleResolution": "node",
    "baseUrl": "./",
    "outDir": "./dist",
    "paths": {
      "@bos/common": ["libs/common/src"],
      "@bos/common/*": ["libs/common/src/*"],
      "@bos/config": ["libs/config/src"],
      "@bos/config/*": ["libs/config/src/*"],
      "@bos/security": ["libs/security/src"],
      "@bos/security/*": ["libs/security/src/*"],
      "@bos/auth-client": ["libs/auth-client/src"],
      "@bos/auth-client/*": ["libs/auth-client/src/*"],
      "@bos/database": ["libs/database/src"],
      "@bos/database/*": ["libs/database/src/*"],
      "@bos/events": ["libs/events/src"],
      "@bos/events/*": ["libs/events/src/*"],
      "@bos/queue": ["libs/queue/src"],
      "@bos/queue/*": ["libs/queue/src/*"],
      "@bos/mailer": ["libs/mailer/src"],
      "@bos/mailer/*": ["libs/mailer/src/*"],
      "@bos/redis": ["libs/redis/src"],
      "@bos/redis/*": ["libs/redis/src/*"],
      "@bos/logger": ["libs/logger/src"],
      "@bos/logger/*": ["libs/logger/src/*"],
      "@bos/health": ["libs/health/src"],
      "@bos/health/*": ["libs/health/src/*"],
      "@bos/errors": ["libs/errors/src"],
      "@bos/errors/*": ["libs/errors/src/*"],
      "@bos/testing": ["libs/testing/src"],
      "@bos/testing/*": ["libs/testing/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
