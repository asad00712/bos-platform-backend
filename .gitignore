apps/**/*.js.map
apps/**/*.d.ts
libs/**/*.js
libs/**/*.js.map
libs/**/*.d.ts
!apps/**/jest.config.js
!libs/**/jest.config.js

# Env files
.env
.env.local
.env.*.local
!.env.example

# Secrets — keys, certs
keys/
*.pem
*.key
!*.pub.pem
!*.public.pem

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing
coverage/
.nyc_output/

# Prisma
prisma/*/migrations/dev.db*

# Temp / extract
.brd_extract/
.tmp/
tmp/

# pnpm
.pnpm-store/

