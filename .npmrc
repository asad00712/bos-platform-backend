auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
# Hoist Prisma internals so generated clients in node_modules/@bos-prisma/* can resolve them
public-hoist-pattern[]=@prisma/client-runtime-utils
public-hoist-pattern[]=@prisma/debug
public-hoist-pattern[]=@prisma/config
link-workspace-packages=true
prefer-workspace-packages=true
save-exact=false
engine-strict=true
fetch-retries=5
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
fetch-timeout=600000
network-concurrency=4
