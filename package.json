{
  "name": "bos-backend",
  "version": "0.1.0",
  "description": "BOS — Business Operating System. Multi-tenant SaaS backend monorepo.",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nest build",
    "build:auth": "nest build auth-service",
    "start:auth": "nest start auth-service",
    "start:auth:dev": "nest start auth-service --watch",
    "start:auth:debug": "nest start auth-service --watch --debug",
    "build:crm-core": "nest build crm-core",
    "start:crm-core": "nest start crm-core",
    "start:crm-core:dev": "nest start crm-core --watch",
    "start:crm-core:debug": "nest start crm-core --watch --debug",
    "db:generate": "pnpm db:generate:core && pnpm db:generate:tenant && pnpm db:generate:volatile",
    "db:generate:core": "prisma generate --config=prisma/core/prisma.config.ts",
    "db:generate:tenant": "prisma generate --config=prisma/tenant-template/prisma.config.ts",
    "db:generate:volatile": "prisma generate --config=prisma/volatile/prisma.config.ts",
    "db:migrate:core:dev": "prisma migrate dev --config=prisma/core/prisma.config.ts",
    "db:migrate:core:deploy": "prisma migrate deploy --config=prisma/core/prisma.config.ts",
    "db:migrate:tenant:dev": "prisma migrate dev --config=prisma/tenant-template/prisma.config.ts --create-only",
    "db:migrate:volatile:dev": "prisma migrate dev --config=prisma/volatile/prisma.config.ts",
    "db:migrate:volatile:deploy": "prisma migrate deploy --config=prisma/volatile/prisma.config.ts",
    "db:reset:core": "prisma migrate reset --config=prisma/core/prisma.config.ts",
    "db:reset:volatile": "prisma migrate reset --config=prisma/volatile/prisma.config.ts",
    "db:studio:core": "prisma studio --config=prisma/core/prisma.config.ts",
    "db:studio:volatile": "prisma studio --config=prisma/volatile/prisma.config.ts",
    "db:format": "prisma format --config=prisma/core/prisma.config.ts && prisma format --config=prisma/tenant-template/prisma.config.ts && prisma format --config=prisma/volatile/prisma.config.ts",
    "db:seed:core": "ts-node --transpile-only -r tsconfig-paths/register prisma/core/seed.ts",
    "db:seed": "pnpm db:seed:core",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "lint:fix": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typecheck": "tsc --noEmit",
    "docker:dev:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker/docker-compose.dev.yml logs -f",
    "docker:dev:ps": "docker compose -f docker/docker-compose.dev.yml ps",
    "redis:up": "docker compose -f docker/docker-compose.dev.yml up -d redis-operational redis-queue-transactional redis-queue-heavy",
    "redis:down": "docker compose -f docker/docker-compose.dev.yml down redis-operational redis-queue-transactional redis-queue-heavy",
    "redis:logs": "docker compose -f docker/docker-compose.dev.yml logs -f redis-operational redis-queue-transactional redis-queue-heavy",
    "redis:restart": "docker compose -f docker/docker-compose.dev.yml restart redis-operational redis-queue-transactional redis-queue-heavy",
    "prepare": "husky || true"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "unrs-resolver",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "~22.10.10",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "prisma": "^7.7.0",
    "run-script-webpack-plugin": "^0.2.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.58.2",
    "webpack": "^5.106.1",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/client-runtime-utils": "7.7.0",
    "argon2": "^0.44.0",
    "bullmq": "5.74.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jose": "^6.2.2",
    "lru-cache": "^11.3.5",
    "nestjs-pino": "^4.6.1",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "resend": "6.12.0",
    "rxjs": "^7.8.2"
  }
}
