# ============================================================
# BOS Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit the .env file.
# ============================================================

# ----- Runtime -----
NODE_ENV=development
LOG_LEVEL=debug

# ----- Auth Service -----
AUTH_SERVICE_PORT=3001
AUTH_JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
AUTH_JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ACCESS_TTL=900              # 15 minutes (seconds)
AUTH_JWT_REFRESH_TTL=2592000         # 30 days (seconds)
AUTH_JWT_PLATFORM_ACCESS_TTL=300     # 5 minutes for platform scope
AUTH_BCRYPT_COST=12
AUTH_LOCKOUT_MAX_ATTEMPTS=10
AUTH_LOCKOUT_DURATION=1800           # 30 minutes (seconds)
AUTH_INVITE_TTL=172800               # 48 hours (seconds)
AUTH_EMAIL_VERIFY_TTL=86400          # 24 hours (seconds)
AUTH_PASSWORD_RESET_TTL=3600         # 1 hour (seconds)
AUTH_2FA_TEMP_TOKEN_TTL=300          # 5 minutes (seconds)

# ----- CRM Core Service -----
CRM_CORE_PORT=3002

# ----- Campaign Service -----
CAMPAIGN_SERVICE_PORT=3003

# ----- Communication Service -----
COMMUNICATION_SERVICE_PORT=3004

# ----- File Service -----
FILE_SERVICE_PORT=3005

# ----- Audit Service -----
AUDIT_SERVICE_PORT=3006

# ----- Notification Service -----
NOTIFICATION_SERVICE_PORT=3007

# ----- Webhook Service -----
WEBHOOK_SERVICE_PORT=3008

# ----- Databases (2 Postgres) -----
# Core DB — global public schema + per-tenant schemas (tenant_{uuid})
DATABASE_URL_CORE=postgresql://postgres:postgres@localhost:5435/bos_core?schema=public

# Volatile DB — high-volume ephemeral data (audit logs, campaign tracking)
# Audit logs: 100-day retention | Campaign data: 30-day retention
# Auto-drop via pg_partman or scheduled job
DATABASE_URL_VOLATILE=postgresql://postgres:postgres@localhost:5435/bos_volatile

# ----- Redis 1 — Operational (revocation, rate limits, sessions, pub/sub, cache) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----- Redis 2 — Transactional Queue (auth emails, notifications, webhooks, AI leads) -----
REDIS_QUEUE_TRANSACTIONAL_HOST=localhost
REDIS_QUEUE_TRANSACTIONAL_PORT=6380
REDIS_QUEUE_TRANSACTIONAL_PASSWORD=

# ----- Redis 3 — Heavy Queue (campaigns, workflows, bulk imports) -----
REDIS_QUEUE_HEAVY_HOST=localhost
REDIS_QUEUE_HEAVY_PORT=6381
REDIS_QUEUE_HEAVY_PASSWORD=

# ----- CORS -----
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ----- Rate Limiting -----
THROTTLE_TTL=60
THROTTLE_LIMIT=1000

# ----- Frontend URL (used to build email links) -----
APP_FRONTEND_URL=http://localhost:3000

# ----- Email (Resend) -----
RESEND_API_KEY=re_b54NDhjn_AfMD8GeMheck9SiKSsRThDRg
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@bos.example.com

# ----- SMS (Twilio / Africa's Talking) -----
SMS_PROVIDER=twilio                  # twilio | africastalking
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

# ----- File Storage (Cloudflare R2 — S3-compatible API) -----
# R2 endpoint format: https://<account_id>.r2.cloudflarestorage.com
# Get account ID + create API token in Cloudflare dashboard → R2 → Manage API Tokens
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=bos-files
S3_FORCE_PATH_STYLE=true
# Public bucket URL (for direct file access if bucket is configured public)
S3_PUBLIC_URL=https://pub-<hash>.r2.dev

# ----- Payments -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----- Observability -----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=

# ----- SSO (Google / Microsoft) -----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_CALLBACK_URL=
